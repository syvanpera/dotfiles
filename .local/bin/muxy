#!/bin/bash

SESSION_NAME="mysession"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    # Find the terminal window running tmux
    WINDOW_ID=$(hyprctl clients | grep -B4 "ghostty - tmux" | grep "Window" | awk '{print $2}' | head -n 1)

    if [ -n "$WINDOW_ID" ]; then
        hyprctl dispatch focuswindow address:$WINDOW_ID
        exit 0
    else
        echo "Session exists but no matching window found."
    fi
else
    uwsm app -- ghostty --title='ghostty - tmux' -e tmux new-session -s "$SESSION_NAME" &
fi
