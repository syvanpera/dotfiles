main() {
  setup_colors

  if [[ $# -lt 1 ]]; then
    usage
  fi

  case "$1" in
    clone)
      shift
      clone "$@"
      ;;
    checkout)
      shift
      checkout "$@"
      ;;
    list | ls)
      shift
      list "$@"
      ;;
    # checkout | co)
    #   shift
    #   checkout "$@"
    #   ;;
    -h | --help)
      usage
      ;;
    *)
      die "Unknown command: $1"
      ;;
  esac
}

main "$@"
